postgres.film_ratings", "compiled": true, "compiled_code": "WITH films_with_ratings AS (\n    SELECT\n        f.film_id,\n        f.title,\n        f.release_date,\n        f.price,\n        f.rating, \n        f.user_rating,\n        case\n    when f.user_rating >= 4.5 then 'Excellent'\n    when f.user_rating >= 4.0 then 'Good'\n    when f.user_rating >= 3.0 then 'Average'\n    else 'Poor'\nend AS rating_category\n    FROM films f    \n),\n\nfilms_with_actors AS (\n    SELECT\n        f.film_id,\n        f.title,\n        STRING_AGG(a.actor_name, ', ') AS actors\n    FROM films f\n    LEFT JOIN film_actors fa ON f.film_id = fa.film_id\n    LEFT JOIN actors a ON fa.actor_id = a.actor_id\n    GROUP BY f.film_id, f.title \n)\n\nSELECT \n    fwr.*,\n    fwa.actors\nFROM films_with_ratings fwr\nLEFT JOIN films_with_actors fwa ON fwr.film_id = fwa.film_id", "relation_name": "\"destination_db\".\"public\".\"film_ratings\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-13T16:57:59.112927Z", "completed_at": "2026-04-13T16:57:59.114615Z"}, {"name": "execute", "started_at": "2026-04-13T16:57:59.114858Z", "completed_at": "2026-04-13T16:57:59.141566Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.03004908561706543, "adapter_response": {"_message": "SELECT 20", "code": "SELECT", "rows_affected": 20}, "message": "SELECT 20", "failures": null, "unique_id": "model.custom_postgres.films", "compiled": true, "compiled_code": "SELECT * FROM films", "relation_name": "\"destination_db\".\"public\".\"films\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-13T16:57:59.147373Z", "completed_at": "2026-04-13T16:57:59.149837Z"}, {"name": "execute", "started_at": "2026-04-13T16:57:59.150247Z", "completed_at": "2026-04-13T16:57:59.179151Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.033599853515625, "adapter_response": {"_message": "SELECT 7", "code": "SELECT", "rows_affected": 7}, "message": "SELECT 7", "fail