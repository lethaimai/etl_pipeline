": "SELECT", "rows_affected": 20}, "message": "SELECT 20", "failures": null, "unique_id": "model.custom_postgres.film_ratings", "compiled": true, "compiled_code": "WITH films_with_ratings AS (\n    SELECT\n        f.film_id,\n        f.title,\n        f.release_date,\n        f.price,\n        f.rating, \n        f.user_rating,\n        case\n    when f.user_rating >= 4.5 then 'Excellent'\n    when f.user_rating >= 4.0 then 'Good'\n    when f.user_rating >= 3.0 then 'Average'\n    else 'Poor'\nend AS rating_category\n    FROM films f    \n),\n\nfilms_with_actors AS (\n    SELECT\n        f.film_id,\n        f.title,\n        STRING_AGG(a.actor_name, ', ') AS actors\n    FROM films f\n    LEFT JOIN film_actors fa ON f.film_id = fa.film_id\n    LEFT JOIN actors a ON fa.actor_id = a.actor_id\n    GROUP BY f.film_id, f.title \n)\n\nSELECT \n    fwr.*,\n    fwa.actors\nFROM films_with_ratings fwr\nLEFT JOIN films_with_actors fwa ON fwr.film_id = fwa.film_id", "relation_name": "\"destination_db\".\"public\".\"film_ratings\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-13T14:34:52.169934Z", "completed_at": "2026-04-13T14:34:52.170721Z"}, {"name": "execute", "started_at": "2026-04-13T14:34:52.170832Z", "completed_at": "2026-04-13T14:34:52.186802Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.01731419563293457, "adapter_response": {"_message": "SELECT 20", "code": "SELECT", "rows_affected": 20}, "message": "SELECT 20", "failures": null, "unique_id": "model.custom_postgres.films", "compiled": true, "compiled_code": "SELECT * FROM films", "relation_name": "\"destination_db\".\"public\".\"films\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-13T14:34:52.188164Z", "completed_at": "2026-04-13T14:34:52.188953Z"}, {"name": "execute", "started_at": "2026-04-13T14:34:52.189060Z", "completed_at": "2026-04-13T14:34:52.204839Z"}], "thread_id": "Thread-1 (worker)",